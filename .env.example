# ============================================================
# EcoChain Protocol — Variáveis de Ambiente
# Autora: Mirtes Fernanda Dutra da Silva
# ============================================================
# ATENÇÃO: NUNCA commite este arquivo com valores reais!
#          Adicione .env ao .gitignore (já configurado)
# ============================================================

# Chave privada da carteira de deploy (sem o "0x" na frente)
# Obtenha do MetaMask: Configurações > Segurança > Exportar chave privada
PRIVATE_KEY=sua_chave_privada_aqui

# URL RPC da Sepolia
# Opções gratuitas:
#   - Alchemy: https://www.alchemy.com/ (recomendado)
#   - Infura: https://www.infura.io/
#   - Pública: https://rpc.sepolia.org
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SUA_API_KEY

# API Key do Etherscan (para verificar contratos)
# Obtenha em: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=sua_api_key_etherscan

# Opcional: ativar relatório de gas
REPORT_GAS=false
